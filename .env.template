# Basic Auth для backend API и admin panel
INDEXER_API_USERNAME=admin
INDEXER_API_PASSWORD=change-me-api-password

# Пароль Bitcoin JSON-RPC, на который ссылается config/indexer.yaml
BITCOIN_RPC_PASSWORD=change-me-rpc-password

# PostgreSQL для backend внутри docker compose
DATABASE_URL=postgres://indexer:indexer@postgres:5432/indexer

# Необязательные переопределения
# INDEXER_CONFIG_PATH=config/indexer.yaml
