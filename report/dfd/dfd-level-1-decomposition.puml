@startuml DFD_Level_1
!include dfd-notation.puml

title DFD 1 уровня - Декомпозиция процессов индексера

ExternalEntity(E1, "E1 Клиентские системы")
ExternalEntity(E2, "E2 Bitcoin Core RPC Proxy")
ExternalEntity(E3, "E3 Контур мониторинга")

Process(P1, "P1 Индексация данных")
Process(P2, "P2 Администрирование jobs")
Process(P3, "P3 Получение/выдача данных")

DataStore(D1, "D1 Операционное хранилище индексера")
DataStore(D2, "D2 Конфигурация и состояние jobs")

Flow(E1, P2, "Команды управления jobs")
Flow(P2, E1, "Статусы выполнения команд")
Flow(E1, P3, "Запросы на получение блокчейн-данных")
Flow(P3, E1, "Ответы с данными/ошибками")

Flow(P2, D2, "Создание/обновление конфигурации и статусов")
Flow(D2, P2, "Текущие состояния и параметры jobs")

Flow(P2, P1, "Сигналы запуска/паузы/возобновления")
Flow(P1, D2, "Прогресс jobs, ошибки, служебные статусы")
Flow(D2, P1, "Параметры активных jobs")

Flow(P1, E2, "RPC-запросы на блоки/транзакции/mempool")
Flow(E2, P1, "Ответы RPC")
Flow(P1, D1, "Нормализованные блоки/tx/utxo/балансы")

Flow(P3, D1, "Чтение индексированных данных")
Flow(P3, E2, "RPC fallback при отсутствии данных")
Flow(E2, P3, "Данные для fallback-ответа")
Flow(P3, D1, "Дозапись полученных fallback-данных")

Flow(P1, E3, "Метрики индексации и логи")
Flow(P2, E3, "Метрики и логи администрирования")
Flow(P3, E3, "Метрики и логи выдачи данных")

@enduml
