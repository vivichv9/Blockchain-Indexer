@startuml DFD_Level_2_DataServing
!include dfd-notation.puml

title DFD 2 уровня - Детализация процесса P3 Получение/выдача данных

ExternalEntity(E1, "E1 Клиентские системы")
ExternalEntity(E2, "E2 Bitcoin Core RPC Proxy")

Process(P31, "P3.1 Прием запроса и валидация параметров")
Process(P32, "P3.2 Поиск данных в индексе")
Process(P33, "P3.3 Получение данных из узла (fallback)")
Process(P34, "P3.4 Нормализация и дозапись в индекс")
Process(P35, "P3.5 Формирование и выдача ответа")

DataStore(D1, "D1 Операционное хранилище индексера")

Flow(E1, P31, "Запросы данных: block/tx/address/mempool")
Flow(P31, P32, "Нормализованный поисковый запрос")

Flow(P32, D1, "Чтение данных по ключам запроса")
Flow(D1, P32, "Данные найдены/данные отсутствуют")
Flow(P32, P35, "Локальные данные (если найдено)")
Flow(P32, P33, "Сигнал fallback (если не найдено)")

Flow(P33, E2, "RPC-запрос при отсутствии данных в индексе")
Flow(E2, P33, "Данные узла")
Flow(P33, P34, "Сырые данные для нормализации")

Flow(P34, D1, "Дозапись/обновление индекса")
Flow(P34, P35, "Данные после нормализации")

Flow(P35, E1, "Ответ API")

@enduml
