@startuml DFD_Level_2_Admin
!include dfd-notation.puml

title DFD 2 уровня - Детализация процесса P2 Администрирование jobs

ExternalEntity(E1, "E1 Клиентские системы")
Process(P21, "P2.1 Прием и аутентификация команды")
Process(P22, "P2.2 Валидация перехода состояния")
Process(P23, "P2.3 Применение команды к job")
Process(P24, "P2.4 Формирование ответа API")

DataStore(D2, "D2 Конфигурация и состояние jobs")

Flow(E1, P21, "Команды: create/start/pause/resume/stop/status")
Flow(P21, P22, "Аутентифицированная команда")

Flow(P22, D2, "Чтение текущего состояния job")
Flow(D2, P22, "Текущее состояние и политика переходов")
Flow(P22, P23, "Разрешенная команда или ошибка валидации")

Flow(P23, D2, "Обновление статуса/конфига/временных меток")
Flow(D2, P23, "Подтверждение записи")
Flow(P23, P24, "Итог выполнения команды")

Flow(P24, E1, "API-ответ: новый статус/ошибка")

@enduml
