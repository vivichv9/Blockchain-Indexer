FROM node:22-alpine AS builder
WORKDIR /app

ARG VITE_INDEXER_API_BASE_URL=/api
ARG VITE_INDEXER_API_USERNAME=admin
ARG VITE_INDEXER_API_PASSWORD=changeme

ENV VITE_INDEXER_API_BASE_URL=$VITE_INDEXER_API_BASE_URL
ENV VITE_INDEXER_API_USERNAME=$VITE_INDEXER_API_USERNAME
ENV VITE_INDEXER_API_PASSWORD=$VITE_INDEXER_API_PASSWORD

COPY package.json ./
RUN npm install

COPY . .
RUN npm run build

FROM nginx:1.27-alpine
COPY nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=builder /app/dist /usr/share/nginx/html

EXPOSE 80
